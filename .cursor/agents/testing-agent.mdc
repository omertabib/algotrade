## Signal Aggregation Test Template

```python
from unittest.mock import MagicMock
from your_package.enums import ActionEnum
from your_package.signal_engine import SignalEngine


def make_strategy(vote: ActionEnum):
    s = MagicMock()
    s.evaluate.return_value = vote
    return s


def test_majority_buy_triggers_execution():
    strategies = [make_strategy(ActionEnum.BUY)] * 3 + [make_strategy(ActionEnum.SELL)]
    engine = SignalEngine(strategies=strategies, execution_engine=MagicMock())
    engine.process_tick(symbol="AAPL", price=100.0, redis=MagicMock())
    engine.execution_engine.execute_buy.assert_called_once()


def test_no_majority_does_not_trade():
    strategies = [make_strategy(ActionEnum.BUY), make_strategy(ActionEnum.SELL), make_strategy(ActionEnum.HOLD)]
    engine = SignalEngine(strategies=strategies, execution_engine=MagicMock())
    engine.process_tick(symbol="AAPL", price=100.0, redis=MagicMock())
    engine.execution_engine.execute_buy.assert_not_called()
    engine.execution_engine.execute_sell.assert_not_called()


def test_all_hold_does_not_trade():
    strategies = [make_strategy(ActionEnum.HOLD)] * 5
    engine = SignalEngine(strategies=strategies, execution_engine=MagicMock())
    engine.process_tick(symbol="AAPL", price=100.0, redis=MagicMock())
    engine.execution_engine.execute_buy.assert_not_called()
```

