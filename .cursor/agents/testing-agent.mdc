## MockPortfolio Test Template

```python
from your_package.portfolio import MockPortfolio


def test_buy_deducts_cash():
    portfolio = MockPortfolio(cash=10_000.0)
    portfolio.buy("AAPL", quantity=10, price=100.0)
    assert portfolio.cash == 9_000.0
    assert portfolio.holdings["AAPL"].quantity == 10


def test_sell_closes_full_position():
    portfolio = MockPortfolio(cash=10_000.0)
    portfolio.buy("AAPL", quantity=10, price=100.0)
    portfolio.sell("AAPL", price=120.0)
    assert "AAPL" not in portfolio.holdings
    assert portfolio.cash == pytest.approx(10_200.0)  # 9000 + 1200


def test_stop_loss_triggers():
    portfolio = MockPortfolio(cash=10_000.0, stop_loss_pct=0.02)
    portfolio.buy("AAPL", quantity=10, price=100.0)
    portfolio.update_market_price("AAPL", 97.0)  # 3% drop > 2% stop-loss
    assert "AAPL" not in portfolio.holdings  # position auto-closed


def test_stop_loss_does_not_trigger_within_threshold():
    portfolio = MockPortfolio(cash=10_000.0, stop_loss_pct=0.02)
    portfolio.buy("AAPL", quantity=10, price=100.0)
    portfolio.update_market_price("AAPL", 99.0)  # 1% drop < 2% stop-loss
    assert "AAPL" in portfolio.holdings
```

