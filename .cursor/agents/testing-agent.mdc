## Strategy Test Template

Every strategy MUST have tests for these four cases at minimum:

```python
import pytest
from unittest.mock import MagicMock
from your_package.enums import ActionEnum
from your_package.strategies.my_strategy import MyStrategy


@pytest.fixture
def redis_mock():
    return MagicMock()


def test_my_strategy_buy_signal(redis_mock):
    """Strategy triggers BUY given conditions X."""
    redis_mock.get_price_history.return_value = [90.0, 91.0, 95.0, 100.0]  # craft uptrend
    strategy = MyStrategy(period=4)
    result = strategy.evaluate("AAPL", current_price=100.0, redis=redis_mock)
    assert result == ActionEnum.BUY


def test_my_strategy_sell_signal(redis_mock):
    """Strategy triggers SELL given conditions Y."""
    redis_mock.get_price_history.return_value = [110.0, 105.0, 100.0, 90.0]  # downtrend
    strategy = MyStrategy(period=4)
    result = strategy.evaluate("AAPL", current_price=90.0, redis=redis_mock)
    assert result == ActionEnum.SELL


def test_my_strategy_hold_on_insufficient_data(redis_mock):
    """Returns HOLD — not an error — when history is too short."""
    redis_mock.get_price_history.return_value = [100.0]  # only 1 point, period=20
    strategy = MyStrategy(period=20)
    result = strategy.evaluate("AAPL", current_price=100.0, redis=redis_mock)
    assert result == ActionEnum.HOLD


def test_my_strategy_hold_on_neutral_market(redis_mock):
    """Returns HOLD when market is flat — no conviction."""
    redis_mock.get_price_history.return_value = [100.0] * 20  # flat
    strategy = MyStrategy(period=20)
    result = strategy.evaluate("AAPL", current_price=100.0, redis=redis_mock)
    assert result == ActionEnum.HOLD
```

