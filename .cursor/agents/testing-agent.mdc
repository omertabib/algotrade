## Provider Transform Test Template

```python
from datetime import datetime
from your_package.providers.alpaca import AlpacaDataProvider, AlpacaTick


def test_transform_valid_tick():
    provider = AlpacaDataProvider()
    raw = AlpacaTick(symbol="AAPL", price=150.0, size=10, time=datetime.utcnow())
    result = provider.transform_data(raw)
    assert result.is_ok()
    tick = result.ok()
    assert tick.symbol == "AAPL"
    assert tick.price == 150.0
    assert tick.quantity == 10


def test_transform_rejects_zero_price():
    provider = AlpacaDataProvider()
    raw = AlpacaTick(symbol="AAPL", price=0.0, size=10, time=datetime.utcnow())
    result = provider.transform_data(raw)
    assert result.is_err()


def test_transform_rejects_negative_price():
    provider = AlpacaDataProvider()
    raw = AlpacaTick(symbol="AAPL", price=-5.0, size=10, time=datetime.utcnow())
    result = provider.transform_data(raw)
    assert result.is_err()


def test_received_at_is_set():
    provider = AlpacaDataProvider()
    raw = AlpacaTick(symbol="TSLA", price=200.0, size=5, time=datetime.utcnow())
    result = provider.transform_data(raw)
    assert result.ok().received_at is not None
```

