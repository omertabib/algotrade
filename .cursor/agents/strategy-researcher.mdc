    assert strategy.evaluate("AAPL", 100.0, redis_mock) == ActionEnum.HOLD


def test_<strategy>_hold_neutral_market(redis_mock):
    redis_mock.get_price_history.return_value = [100.0] * 20  # flat
    strategy = <StrategyName>Strategy(period=20)
    assert strategy.evaluate("AAPL", 100.0, redis_mock) == ActionEnum.HOLD
