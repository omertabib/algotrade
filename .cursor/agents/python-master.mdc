## Async Redis Patterns

### Always use pipeline for multi-operation writes
```python
async def publish_and_cache(self, tick: NormalizedTick) -> None:
    async with self.redis.pipeline(transaction=False) as pipe:
        pipe.publish(tick.symbol, tick.model_dump_json())
        pipe.lpush(f"history:{tick.symbol}", tick.price)
        pipe.ltrim(f"history:{tick.symbol}", 0, self.max_history - 1)
        await pipe.execute()
```

### History reads with explicit type cast
```python
async def get_price_history(self, symbol: str, limit: int) -> list[float]:
    raw: list[bytes] = await self.redis.lrange(f"history:{symbol}", 0, limit - 1)
    return [float(v) for v in raw]
```

### Subscriber pattern
```python
async def subscribe_and_process(self) -> None:
    async with self.redis.pubsub() as pubsub:
        await pubsub.subscribe(*self.symbols)
        async for message in pubsub.listen():
            if message["type"] != "message":
                continue
            await self._handle_message(message["data"])
```

